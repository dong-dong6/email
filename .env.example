# Optional. Docker Compose can start without this file.

# Exposed backend port on the VPS.
API_HTTP_PORT=8080

# Address shown to clients and docs. Use your VPS IP or domain.
PUBLIC_URL=http://your-server-ip:8080

# Only needed if you use the Web client from a browser origin not listed here.
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3000
