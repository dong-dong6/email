APP_ENV=development
HTTP_ADDR=:8080
PUBLIC_URL=https://mail.example.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:3000

# Production must set a 32-byte base64 key. Example:
# openssl rand -base64 32
MASTER_KEY_BASE64=

OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=change-me-now
# Optional stronger form generated by backend auth helper in future:
OWNER_PASSWORD_HASH=
OWNER_TOTP_SECRET=

DATA_DIR=/data
BLOB_DIR=/data/blobs

POSTGRES_DB=email
POSTGRES_USER=email
POSTGRES_PASSWORD=change-postgres-password
DATABASE_URL=postgres://email:change-postgres-password@postgres:5432/email?sslmode=disable

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_PUBSUB_TOPIC=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
